# Supabase Config (Get from Supabase Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Agora Config (Required for Dynamic Voice/Video Call and Token Generation)
NEXT_PUBLIC_AGORA_APP_ID=YOUR_AGORA_APP_ID
AGORA_APP_CERTIFICATE=YOUR_AGORA_APP_CERTIFICATE

# AI/LLM SDK Config (Llama 3.3 model via Groq API)
OPENAI_API_KEY=YOUR_GROQ_API_KEY
NEXT_PUBLIC_AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile

